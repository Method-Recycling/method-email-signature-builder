{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": ["dist/css/bulma-divider.min.css", "src/**", "node_modules/**", "reports/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noVar": "off",
        "useConst": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  }
}
